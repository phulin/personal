---
import { execFileSync } from "node:child_process";
import fs from "node:fs";
import path from "node:path";
import MarkdownIt from "markdown-it";
import Layout from "../layouts/Layout.astro";

const md = new MarkdownIt({ html: true, linkify: true });
const rootDir = process.cwd();

function stripFrontMatter(content) {
	const match = content.match(/^---\r?\n[\s\S]*?\r?\n---\r?\n/);
	if (match) {
		return content.slice(match[0].length);
	}
	return content;
}

function readMarkdown(relativePath) {
	const raw = fs.readFileSync(path.join(rootDir, relativePath), "utf8");
	return stripFrontMatter(raw).trim();
}

function getPostDate(relativePath) {
	try {
		const out = execFileSync(
			"git",
			["log", "-1", "--format=%cI", "--", relativePath],
			{ cwd: rootDir, encoding: "utf8" },
		).trim();
		if (out) return new Date(out);
	} catch {}
	return fs.statSync(path.join(rootDir, relativePath)).mtime;
}

const blogDir = path.join(rootDir, "content/blog");
const posts = fs.readdirSync(blogDir);
const sortedPosts = posts
	.map((post) => ({
		slug: post.replace(".md", ""),
		markdown: readMarkdown(`content/blog/${post}`),
		date: getPostDate(`content/blog/${post}`),
	}))
	.sort((a, b) => b.date.getTime() - a.date.getTime());
const postContent = sortedPosts.map(({ slug, markdown, date }) => {
	const title = markdown.match(/^#\s+(.*)/)?.[1] || "Untitled Post";
	const html = md.render(markdown);
	return { title, slug, date, html };
});
---

<Layout title="patrick hulin's internet blog">
  <center><h1 style="margin-bottom: 3rem">patrick's internet blog</h1></center>
  {
    postContent.map(({ slug, date, html }) => (
      <article id={slug}>
        <a href={`/blog#${slug}`}>
          <h2 style="margin-bottom: 0.5rem">
            <time datetime={date.toISOString()}>
              {date.toLocaleString("en-US", { weekday: "long", year: "numeric", month: "long", day: "numeric", hour: "numeric", minute: "2-digit" })}
            </time>
          </h2>
        </a>
        <div set:html={html}></div>
      </article>
    ))
  }
</Layout>
